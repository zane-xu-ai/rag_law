# 复制为 .env 后填写真实值。勿将 .env 提交到版本库。

# ========== LLM（OpenAI 兼容接口，如 DashScope）==========
MODEL_API_KEY=your-api-key-here
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus

# ========== Elasticsearch ==========
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=rag_law_chunks
# 可选：启用安全与 HTTPS 时填写
# ES_USER=elastic
# ES_PASSWORD=changeme
# ES_USE_SSL=false

# ========== 切分与检索（MVP：单层字符滑窗）==========
# 单块最大字符数；若未设置 CHUNK_SIZE，可读旧变量 PARENT_CHUNK_SIZE
CHUNK_SIZE=1500
CHUNK_OVERLAP=50
RETRIEVAL_K=5

# ========== 本地向量模型 ==========
# BGE-M3 模型目录（绝对路径或相对项目根的路径）
BGE_M3_PATH=/path/to/bge-m3

# 可选：入库编码批大小
# EMBEDDING_BATCH_SIZE=32
