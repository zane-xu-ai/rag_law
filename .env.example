# =============================================================================
# 使用方式：复制本文件为项目根目录下的 `.env` 并填写真实值。
# 切勿将 `.env` 提交到 Git（已在 .gitignore 中忽略）。
# =============================================================================
#
# 必填项（运行应用 / 测试时由 monkeypatch 注入则不在此表）：
#   MODEL_API_KEY      — LLM API 密钥
#   MODEL_BASE_URL     — OpenAI 兼容接口 Base URL
#   MODEL_NAME         — 模型名
#   BGE_M3_PATH        — 本地 BGE-M3 模型目录（绝对路径或相对项目根）
#
# 常用可选项：
#   ES_HOST / ES_PORT / ES_INDEX — Elasticsearch
#   CHUNK_SIZE / CHUNK_OVERLAP / CHUNK_OVERLAP_MIN / RETRIEVAL_K — 切分与检索
#   ES_USER / ES_PASSWORD / ES_USE_SSL — ES 开启安全时
# =============================================================================

# ---------- LLM（OpenAI 兼容接口，如 DashScope）----------
MODEL_API_KEY=your-api-key-here
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus
# 可选：金标生成 / 评测数据合成等离线任务专用模型；不设置则与 MODEL_NAME 相同
# GENERATE_MODEL_NAME=qwen-plus

# ---------- Elasticsearch ----------
ES_HOST=localhost
ES_PORT=9200
# 文档块索引（rag_law_doc_*）；日志/审计可预留 rag_law_log_*；其它项目 rag_*、agent_* 见 doc/plan/v1.0.3-es-store-plan.md
ES_INDEX=rag_law_doc_chunks
# 可选：集群启用安全与 HTTPS 时填写
# ES_USER=elastic
# ES_PASSWORD=changeme
# ES_USE_SSL=false
# 可选：写入每条 ES chunk 的版本标签（如 1.1.7）；配合入库后 delete_chunks_not_matching_version 可清理旧版本
# CHUNK_VERSION=1.1.7

# ---------- 切分与检索（MVP：单层字符滑窗）----------
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
# 句边界对齐时与上一块重叠的最低字符数（可小于 CHUNK_OVERLAP，未设置则等于 CHUNK_OVERLAP）
# CHUNK_OVERLAP_MIN=40
# 句边界对齐时与上一块重叠的最高字符数（可大于 CHUNK_OVERLAP，未设置则等于 CHUNK_OVERLAP）
# CHUNK_OVERLAP_MAX=160
# 为 true 时启用句边界对齐（在滑窗初值上经重叠夹紧 CHUNK_OVERLAP_MIN/MAX 与句界微调，见 doc/chunk/句边界对齐切分.md）；rag_ingest 在未传 --boundary-aware 时也会采用
# CHUNK_BOUNDARY_AWARE=false
# 句边界扩展扫描半径（字符，≤ CHUNK_SIZE；未设置时取 min(CHUNK_SIZE,800)，且不小于局部探测宽度）
# CHUNK_BOUNDARY_MAX_SCAN=800
# 为 true 时句首对齐优先于重叠区间（允许实际重叠越出 MIN/MAX）
# CHUNK_BOUNDARY_PRIORITY_OVERLAP=false
# 重叠夹紧与句首二次对齐的最大往返轮数（默认 2）
# CHUNK_BOUNDARY_CLAMP_ADJUST_MAX_ROUNDS=2
# 语义合并（相邻块相似度动态合并，默认关闭）
# CHUNK_SEMANTIC_MERGE_ENABLED=false
# CHUNK_SEMANTIC_MERGE_THRESHOLD=0.82
# CHUNK_SEMANTIC_MERGE_MIN_CHARS=220
# CHUNK_SEMANTIC_MERGE_MAX_CHARS=2200
# 语义合并相似度：char_ngram（默认，字符 2-gram）或 embedding（BGE 余弦，与入库向量一致；需 uv sync --extra embedding）
# CHUNK_SEMANTIC_MERGE_SIMILARITY=char_ngram
RETRIEVAL_K=5
# 问答时每条检索片段正文最大字符数（超出截断；默认 1200）
# QA_MAX_CONTEXT_CHARS=1200
# 为 true 时 QA 按上方 CHUNK_* 从本地 source_path 重算块并用覆盖命中的块替换 ES 正文（源文件须存在于项目根下相对路径）
# QA_RESOLVE_CHUNKS_FROM_SOURCE=false
# 兼容旧名：仅当未设置 CHUNK_SIZE 时生效
# PARENT_CHUNK_SIZE=1500

# ---------- 本地向量模型 ----------
BGE_M3_PATH=/path/to/bge-m3
# 可选：强制编码设备（cpu / mps / cuda:0 等）；不设置则由 FlagEmbedding 自动选择（Apple Silicon 上常为 mps）
# BGE_EMBEDDING_DEVICE=
# 与 ES mapping 中 dense_vector 的 similarity 对齐（默认 cosine；索引创建时引用）
# VECTOR_SIMILARITY=cosine

# ---------- 方案 D：文档分段模型（可选；需 uv sync --extra segmentation）----------
# segmentation 额外包含 torch、Pillow、datasets、addict、simplejson、sortedcontainers 等，否则仅装 modelscope 也会在加载 pipeline 时失败。
# 见 doc/plan/v1.1.9-scheme-d-concrete.md、scripts/d04_document_segmentation_export.py
# DOCUMENT_SEGMENTATION_PATH=/path/to/nlp_bert_document-segmentation_chinese-base
# CHUNK_DOC_SEGMENTATION_ENABLED=false
# 以下三项：d04 未传 --min-chars/--max-chars/--split-overlap 时从环境读取（与 conf.settings 默认一致）
# DOC_SEGMENTATION_MIN_CHARS=0
# DOC_SEGMENTATION_MAX_CHARS=1200
# DOC_SEGMENTATION_SPLIT_OVERLAP=0
# v1.1.10 / scripts/d05_heading_presplit_document_segmentation_export.py：标题叶子超过该长度才在段内跑 D；不设则等于 DOC_SEGMENTATION_MAX_CHARS
# DOC_SEGMENTATION_SECTION_MAX_CHARS=
# CHUNK_MD_HEADING_STRATEGY=deepest_with_multiple
# 可选 shallowest_with_multiple（先浅层多头）、none（不标题预切分）
# CHUNK_MD_HEADING_FIXED_LEVEL=
# CHUNK_MD_HEADING_SINGLE_IMMEDIATE_CHILD=strict
# 可选 relaxed（单子级 ``##`` 时仍允许按更深 ``###`` 再切）

# ---------- 可选 ----------
# EMBEDDING_BATCH_SIZE=32
# 向量编码需安装可选依赖：uv sync --extra embedding 或 pip install -e ".[embedding]"

# ---------- 日志（loguru）----------
# 详见 doc/plan/v1.1.0-logging-plan.md
# LOG_LEVEL=INFO
# LOG_FORMAT=text（或 json）
# LOG_FILE=logs/rag-law.log

# ---------- QA 监控（JSONL / ES）----------
# 详见 doc/plan/v1.1.1-monitoring-plan.md §1.1
# MONITOR_LOG_FILE=logs/monitor.log
# MONITOR_ES_INDEX=rag-law-monitor
# MONITOR_ES_ENABLED=false
# TOKEN_COST_ENABLED=true
# TOKEN_PRICE_DOC=doc/price_api/qwen.md
# TOKEN_PRICE_REGION=中国内地
# TOKEN_PRICE_VERSION=qwen-md-v1

# ---------- 模型配置 ----------
# WebUI 模型选择器数据源（启动时加载到内存）
# MODEL_CONFIG_PATH=settings/qwen_model/qwen_free_model_name_ranked.json
# ---------- QA 限流（默认每分钟 2 条，用于测试） ----------
# QA_RATE_LIMIT_ENABLED=true
# QA_RATE_LIMIT_PER_MINUTE=2
# QA 审计日志（仅 qa_audit 事件）
# QA_AUDIT_LOG_FILE=logs/qa-audit.log

# ---------- aliyun oss ----------
# 兼容 OSS SDK V2 推荐命名
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# Bucket 所在地域（必填；华北2 北京为 cn-beijing）
OSS_REGION=cn-hangzhou
# 配置好后可在项目根执行（需 PYTHONPATH=src）：
# PYTHONPATH=src uv run python -m utils.oss_aliyun.cli verify --bucket rag-law --prefix md3/
# 可选：scripts/ingest_oss_md_to_es.py 默认桶与前缀（命令行 --bucket / --prefix 优先）
# OSS_BUCKET=rag-law
# OSS_OBJECT_PREFIX=md3/
# 下载目录（相对项目根；与 Settings.oss_download_dir、c06 笔记本一致）
# OSS_DOWNLOAD_DIR=data/md_minerU
# 可选：显式 endpoint（不填时 SDK 将基于 region 自动构造）
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 兼容旧名（如历史脚本使用 accessKeyId/accessKeySecret）
# accessKeyId=your-oss-access-key-id
# accessKeySecret=your-oss-access-key-secret
